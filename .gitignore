# Flutter / Dart build outputs (single-segment patterns match at any depth)
build/

# TEMPORARY: allow frontend/build/web to be committed so the VPS can `git clone`
# a ready-made static build. Remove this block + the build/web files once the
# VPS pull is confirmed working (see project notes).
!frontend/build/
!frontend/build/web/
!frontend/build/web/**

.cxx/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock

# IDE
.idea/
.vscode/

# Android (multi-segment patterns need **/ to match at any depth)
**/android/.gradle/
**/android/local.properties

# Android release signing — NEVER commit these
**/android/key.properties
**/android/keystore/
*.jks
*.keystore

# iOS
**/ios/Pods/
**/ios/.symlinks/

# Desktop / iOS ephemeral
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/
**/macos/Flutter/ephemeral/
**/ios/Flutter/ephemeral/

# Web
**/web/.dart_tool/

# Backend / secrets
node_modules/
.env
.env.local
.env.production

# General
*.log
*.tmp
.DS_Store
Thumbs.db

# Packaged app binaries (large, not source — build them from CI/locally instead)
*.apk
*.aab
*.ipa

# Contains a real production credential (super_admin password) — never commit
backend/create-admin.js

# Stray duplicate build copy (looks like an unsubstituted installer $dest path)
/$dest/
